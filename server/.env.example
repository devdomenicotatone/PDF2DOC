# Adobe PDF Services API Credentials
# Ottienile gratis su: https://developer.adobe.com/console
# 1. Crea un progetto → Aggiungi "PDF Services API"
# 2. Copia Client ID e Client Secret qui sotto

PDF_SERVICES_CLIENT_ID=your_client_id_here
PDF_SERVICES_CLIENT_SECRET=your_client_secret_here

# Password per proteggere il backend (opzionale)
API_ACCESS_KEY=scegli_una_password_sicura

# Port (opzionale, default: 3000)
# PORT=3000
